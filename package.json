{
  "name": "kaghaz-index",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "example:index": "tsx examples/build-index.ts",
    "example:retrieve": "tsx examples/retrieve.ts",
    "typecheck": "tsc",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "rag",
    "pdf",
    "llm",
    "anthropic",
    "claude",
    "langchain",
    "retrieval",
    "vectorless",
    "tree-index"
  ],
  "author": "Amin Painter <work.aminpainter786@gmail.com>",
  "license": "ISC",
  "description": "Vectorless, reasoning-based RAG. Builds hierarchical tree indices from PDFs and retrieves via LLM-driven tree search.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AminPainter/kaghaz-index.git"
  },
  "bugs": {
    "url": "https://github.com/AminPainter/kaghaz-index/issues"
  },
  "homepage": "https://github.com/AminPainter/kaghaz-index#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "langchain": "^1.3.1",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6"
  }
}
